        theme: {
          extend: {
            colors: {
              "inverse-surface": "#e2e0fc",
              "on-secondary": "#003642",
              "on-secondary-fixed": "#001f27",
              "on-primary-fixed": "#1b1a26",
              "on-tertiary": "#003921",
              "on-tertiary-container": "#008e5b",
              "on-surface-variant": "#c8c5cc",
              "on-primary-container": "#7c7b89",
              "surface-dim": "#111125",
              "surface-container-lowest": "#0c0c1f",
              "secondary-fixed": "#b4ebff",
              background: "#111125",
              "outline-variant": "#47464c",
              "on-background": "#e2e0fc",
              "primary-fixed": "#e3e0f1",
