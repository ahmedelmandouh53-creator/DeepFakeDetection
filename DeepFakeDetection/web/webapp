    <style>
      body {
        background-color: #0f0f1a;
        background-image: radial-gradient(
          circle at 2px 2px,
          rgba(255, 255, 255, 0.05) 1px,
          transparent 0
        );
        background-size: 32px 32px;
      }
      .glass-panel {
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .glow-cyan {
        box-shadow: 0 0 15px rgba(162, 231, 255, 0.3);
      }
      .glow-success {
        box-shadow: 0 0 15px rgba(0, 226, 147, 0.3);
      }
    </style>
  </head>
  <body class="font-body-md text-on-surface selection:bg-secondary/30">
    <input type="file" id="fileInput" accept="image/*" class="hidden" />
    <!-- TopNavBar -->
    <nav
      class="fixed top-0 w-full z-50 bg-surface/40 dark:bg-surface/40 backdrop-blur-xl border-b border-white/10 shadow-[0_0_15px_rgba(162,231,255,0.1)]"
    >
      <div
        class="flex items-center justify-between px-margin-mobile md:px-margin-desktop h-20 max-w-container-max-width mx-auto"
      >
        <div class="flex items-center gap-4">
          <img
            alt="VERIFY_AI Logo"
            class="h-10 w-10"
            src="data:image/png;base64,"
          />
          <span
            class="font-headline-md text-headline-md font-bold tracking-tighter text-secondary"
            >VERIFY_AI</span
          >
        </div>
        <div class="hidden md:flex items-center gap-8">
          <a
            class="text-secondary border-b-2 border-secondary pb-1 font-label-md text-label-md"
            href="#"
            >Upload</a
          >
        </div>
      </div>
    </nav>
    <main
      class="pt-32 pb-24 px-margin-mobile md:px-margin-desktop max-w-container-max-width mx-auto"
    >
      <!-- Hero Section -->
      <section class="flex flex-col items-center text-center mb-16">
        <div
          class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-secondary/10 border border-secondary/20 mb-6"
        >
          <span class="material-symbols-outlined text-[16px] text-secondary"
            >verified_user</span
          >
          <span
            class="font-label-sm text-label-sm text-secondary uppercase tracking-widest"
            >Enterprise-Grade Forensic AI</span
          >
        </div>
        <h1
          class="font-headline-xl text-headline-xl mb-4 bg-gradient-to-r from-on-surface to-secondary bg-clip-text text-transparent"
        >
          Digital Integrity Verified.
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">
          Deploy advanced neural forensic analysis to detect synthetic
          manipulations in media. High-precision scanning for security
          professionals.
        </p>
      </section>
      <!-- Main Upload Interaction -->
      <section class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
        <!-- Upload Zone -->
        <div class="lg:col-span-8">
          <div
            id="uploadZone"
            class="glass-panel rounded-xl p-12 flex flex-col items-center justify-center min-h-[400px] border-2 border-dashed border-secondary/40 hover:border-secondary transition-all group cursor-pointer"
          >
            <div id="uploadPrompt" class="flex flex-col items-center">
              <div
                class="w-20 h-20 rounded-full bg-secondary/5 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
              >
                <span class="material-symbols-outlined text-[48px] text-secondary"
                  >monitoring</span
                >
              </div>
              <h2 class="font-headline-md text-headline-md mb-2">
                Drop a face image here or click to upload
              </h2>
              <p class="font-label-md text-label-md text-on-surface-variant mb-8">
                Supports High-Resolution JPG, PNG (Max 25MB)
              </p>
            </div>
            <img id="previewThumb" class="hidden max-h-48 rounded-lg mb-6 object-contain" alt="Preview" />
            <div id="loadingSpinner" class="hidden flex-col items-center gap-3 mb-6">
              <div class="w-10 h-10 border-2 border-secondary/30 border-t-secondary rounded-full animate-spin"></div>
              <p class="font-label-md text-label-md text-secondary">Analyzing...</p>
            </div>
            <button
              id="analyzeBtn"
              class="px-12 py-4 bg-secondary-container text-on-secondary-fixed font-label-md text-label-md rounded-md glow-cyan hover:brightness-110 active:scale-95 transition-all uppercase tracking-widest font-bold"
            >
              Analyze File
            </button>
          </div>
        </div>
        <!-- Stats & Context Side Panel -->
        <div class="lg:col-span-4 flex flex-col gap-gutter">
          <div class="glass-panel rounded-xl p-6">
            <span
              class="font-label-sm text-label-sm uppercase text-on-surface-variant block mb-4"
              >Verification Protocols</span
            >
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span
                  class="material-symbols-outlined text-secondary text-[20px]"
                  >check_circle</span
                >
                <p class="font-label-md text-label-md">
                  Neural Pattern Recognition
                </p>
              </li>
              <li class="flex items-start gap-3">
                <span
                  class="material-symbols-outlined text-secondary text-[20px]"
                  >check_circle</span
                >
                <p class="font-label-md text-label-md">
                  Frequency Domain Analysis
                </p>
              </li>
              <li class="flex items-start gap-3">
                <span
                  class="material-symbols-outlined text-secondary text-[20px]"
                  >check_circle</span
                >
                <p class="font-label-md text-label-md">
                  Artifact Consistency Check
                </p>
              </li>
            </ul>
          </div>
        </div>
      </section>
      <!-- Features Bento Section -->
      <section class="mt-24">
        <h2 class="font-headline-lg text-headline-lg mb-12 text-center">
          Multi-Layered Detection Engine
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter max-w-3xl mx-auto">
          <div
            class="glass-panel rounded-xl p-8 hover:bg-white/[0.06] transition-colors group"
          >
            <span
              class="material-symbols-outlined text-secondary mb-4 text-[32px]"
              >FilmStrip</span
            >
            <h4 class="font-headline-md text-headline-md mb-2">
              Biometric Alignment
            </h4>
            <p class="font-body-md text-body-md text-on-surface-variant">
              Checks for physiological inconsistencies that AI often fails to
              replicate correctly in facial rendering.
            </p>
          </div>
          <div
            class="glass-panel rounded-xl p-8 hover:bg-white/[0.06] transition-colors group"
          >
            <span
              class="material-symbols-outlined text-secondary mb-4 text-[32px]"
              >filter_center_focus</span
            >
            <h4 class="font-headline-md text-headline-md mb-2">
              Pixel Attribution
            </h4>
            <p class="font-body-md text-body-md text-on-surface-variant">
              Tracing the source camera metadata and identifying GAN-generated
              noise patterns at the pixel level.
            </p>
          </div>
        </div>
      </section>
      <!-- Results Section -->
      <section id="resultsSection" class="mt-16 hidden">
        <h2 class="font-headline-lg text-headline-lg mb-8 text-center">Analysis Results</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter mb-gutter">
          <div class="glass-panel rounded-xl p-6">
            <span class="font-label-sm text-label-sm uppercase text-on-surface-variant tracking-widest block mb-4">Original Image</span>
            <img id="originalImg" class="w-full rounded-lg object-cover" alt="Original" />
          </div>
          <div class="glass-panel rounded-xl p-6">
            <span class="font-label-sm text-label-sm uppercase text-on-surface-variant tracking-widest block mb-4">AI Attention Map (Grad-CAM)</span>
            <img id="heatmapImg" class="w-full rounded-lg object-cover" alt="Heatmap" />
          </div>
        </div>
        <div class="glass-panel rounded-xl p-10 text-center mt-gutter">
          <p class="font-label-sm text-label-sm uppercase text-on-surface-variant tracking-widest mb-4">Forensic Verdict</p>
          <div id="verdictBadge" class="inline-flex items-center gap-3 px-10 py-4 rounded-full mb-6">
            <span class="material-symbols-outlined text-[28px]" id="verdictIcon"></span>
            <span class="font-headline-lg text-headline-lg font-bold" id="verdictText"></span>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant mb-1">Confidence Score</p>
          <p class="font-headline-md text-headline-md mb-4" id="confidenceText"></p>
          <div class="h-2 bg-white/10 rounded-full overflow-hidden max-w-sm mx-auto mb-8">
            <div id="confidenceBar" class="h-full rounded-full transition-all duration-700" style="width:0%"></div>
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant mb-8">
            The model focused on the highlighted regions to make its decision.
          </p>
          <button
            id="resetBtn"
            class="px-10 py-3 border border-secondary/40 rounded-md font-label-sm text-label-sm uppercase hover:bg-secondary/10 transition-colors tracking-widest"
          >
            Analyze Another Image
          </button>
        </div>
      </section>
    </main>
    <!-- Footer -->
    <footer
      class="bg-surface-container-lowest/80 dark:bg-surface-container-lowest/80 backdrop-blur-md border-t border-white/10 relative w-full py-12"
    >
      <div
        class="flex flex-col md:flex-row justify-between items-center px-margin-mobile md:px-margin-desktop gap-8 max-w-container-max-width mx-auto"
      >
        <div class="flex flex-col gap-2">
          <span
            class="font-label-md text-label-md font-bold text-on-surface uppercase tracking-widest"
            >VERIFY_AI</span
          >
          <p class="font-label-sm text-label-sm text-on-surface-variant">
            © 2024 DEEPFAKE DETECTOR LABS. ALL RIGHTS RESERVED.
          </p>
        </div>
        <div class="flex gap-8">
          <a
            class="font-label-sm text-label-sm uppercase tracking-widest text-on-surface-variant hover:text-secondary transition-colors"
            href="#"
            >Documentation</a
          >
          <a
            class="font-label-sm text-label-sm uppercase tracking-widest text-on-surface-variant hover:text-secondary transition-colors"
            href="#"
            >API Reference</a
          >
          <a
            class="font-label-sm text-label-sm uppercase tracking-widest text-on-surface-variant hover:text-secondary transition-colors"
            href="#"
            >Privacy Policy</a
          >
          <a
            class="font-label-sm text-label-sm uppercase tracking-widest text-on-surface-variant hover:text-secondary transition-colors"
            href="#"
            >Terms of Service</a
          >
        </div>
        <div class="flex gap-4">
          <div
            class="w-10 h-10 rounded-md glass-panel flex items-center justify-center hover:text-secondary transition-colors cursor-pointer"
          >
            <span class="material-symbols-outlined text-[20px]">share</span>
          </div>
          <div
            class="w-10 h-10 rounded-md glass-panel flex items-center justify-center hover:text-secondary transition-colors cursor-pointer"
          >
            <span class="material-symbols-outlined text-[20px]">mail</span>
          </div>
        </div>
      </div>
    </footer>
  <script>
    const fileInput      = document.getElementById('fileInput');
    const uploadZone     = document.getElementById('uploadZone');
    const analyzeBtn     = document.getElementById('analyzeBtn');
    const uploadPrompt   = document.getElementById('uploadPrompt');
    const previewThumb   = document.getElementById('previewThumb');
    const loadingSpinner = document.getElementById('loadingSpinner');
    const resultsSection = document.getElementById('resultsSection');
    const originalImg    = document.getElementById('originalImg');
    const heatmapImg     = document.getElementById('heatmapImg');
    const verdictBadge   = document.getElementById('verdictBadge');
    const verdictIcon    = document.getElementById('verdictIcon');
    const verdictText    = document.getElementById('verdictText');
    const confidenceText = document.getElementById('confidenceText');
    const confidenceBar  = document.getElementById('confidenceBar');
    const resetBtn       = document.getElementById('resetBtn');

    let selectedFile = null;

    // Open file picker when zone is clicked (but not when button is clicked)
    uploadZone.addEventListener('click', () => fileInput.click());
    analyzeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (!selectedFile) { fileInput.click(); return; }
      runAnalysis();
    });

    // File selected via picker
    fileInput.addEventListener('change', (e) => {
      if (e.target.files[0]) selectFile(e.target.files[0]);
    });

    // Drag & drop
    uploadZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadZone.classList.add('border-secondary');
    });
    uploadZone.addEventListener('dragleave', () => {
      uploadZone.classList.remove('border-secondary');
    });
    uploadZone.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('border-secondary');
      const f = e.dataTransfer.files[0];
      if (f && f.type.startsWith('image/')) selectFile(f);
    });

    function selectFile(file) {
      selectedFile = file;
      const reader = new FileReader();
      reader.onload = (e) => {
        originalImg.src = e.target.result;
        previewThumb.src = e.target.result;
        uploadPrompt.classList.add('hidden');
        previewThumb.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    }

    async function runAnalysis() {
      if (!selectedFile) return;

      // Show spinner, hide button
      analyzeBtn.classList.add('hidden');
      loadingSpinner.classList.remove('hidden');
      loadingSpinner.classList.add('flex');
      resultsSection.classList.add('hidden');

      const formData = new FormData();
      formData.append('file', selectedFile);

      try {
        const res  = await fetch('/predict', { method: 'POST', body: formData });
        if (!res.ok) throw new Error('Server error ' + res.status);
        const data = await res.json();

        heatmapImg.src = 'data:image/jpeg;base64,' + data.heatmap;

        const isFake = data.prediction === 'FAKE';
        verdictIcon.textContent  = isFake ? 'dangerous'     : 'verified';
        verdictText.textContent  = data.prediction;
        verdictBadge.className   = `inline-flex items-center gap-3 px-10 py-4 rounded-full mb-6 border ${
          isFake
            ? 'bg-red-500/20 text-red-400 border-red-500/40'
            : 'bg-tertiary/20 text-tertiary border-tertiary/40'
        }`;

        confidenceText.textContent = data.confidence.toFixed(1) + '%';
        confidenceBar.style.width  = data.confidence + '%';
        confidenceBar.className    = `h-full rounded-full transition-all duration-700 ${
          isFake ? 'bg-red-400' : 'bg-tertiary'
        }`;

        resultsSection.classList.remove('hidden');
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (err) {
        alert('Analysis failed: ' + err.message + '\n\nMake sure the backend is running on http://localhost:8000');
      } finally {
        loadingSpinner.classList.add('hidden');
        loadingSpinner.classList.remove('flex');
        analyzeBtn.classList.remove('hidden');
      }
    }

    resetBtn.addEventListener('click', () => {
      selectedFile = null;
      fileInput.value = '';
      resultsSection.classList.add('hidden');
      previewThumb.classList.add('hidden');
      uploadPrompt.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
  </body>
</html>
